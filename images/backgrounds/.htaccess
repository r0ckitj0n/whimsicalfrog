# Allow access to image files
<FilesMatch "\.(png|jpe?g|gif|webp|avif|svg)$">
    Require all granted
</FilesMatch>

# Enable content type headers
<IfModule mod_mime.c>
    AddType image/jpeg .jpg .jpeg
    AddType image/png .png
    AddType image/gif .gif
    AddType image/webp .webp
    AddType image/avif .avif
    AddType image/svg+xml .svg
</IfModule>

# Cache policy for admin-editable runtime media:
# - keep cache modest (1 hour) to reduce stale images after admin updates
# - require revalidation when max-age expires
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/png "access plus 1 hour"
    ExpiresByType image/jpg "access plus 1 hour"
    ExpiresByType image/jpeg "access plus 1 hour"
    ExpiresByType image/gif "access plus 1 hour"
    ExpiresByType image/webp "access plus 1 hour"
    ExpiresByType image/avif "access plus 1 hour"
    ExpiresByType image/svg+xml "access plus 1 hour"
</IfModule>

<IfModule mod_headers.c>
    Header set Cache-Control "public, max-age=3600, must-revalidate"
    Header set Vary "Accept"
</IfModule>

FileETag MTime Size

# Prevent directory browsing
Options -Indexes

# Allow direct access to files
Options +FollowSymLinks
